# Server-side only. Do not put these values in frontend code.
DATABASE_URL=
USDA_FDC_API_KEY=
OPENFOODFACTS_ENABLED=true
NUTRITION_CACHE_TTL_DAYS=30
DIET_PLANNER_AUTO_PROVISION=true
PORT=3000

# Non-production fallback only:
# When DATABASE_URL is missing and NODE_ENV is not production, the backend uses ./backend/data JSON files.
# Do not use DIET_PLANNER_DATA_DIR for the production Supabase Postgres architecture.
